# ===================================
# NewsLingo News Fetch Configuration
# ===================================

# --- Required ---
# Worldnewsapi (get from https://worldnewsapi.com/console)
WORLDNEWS_API_KEY=your_worldnews_key_here

# Supabase
SUPABASE_URL=https://qwxsntvobtfjldurswfq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Optional (for AI mode) ---
# Groq (free - get key from https://console.groq.com/keys)
# OPENAI_API_KEY=gsk-your-groq-api-key
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Usage:
#   python3 fetch_news.py 10              ← 10 articles, auto mode
#   python3 fetch_news.py --mode raw 10   ← 10 articles, no AI
#   python3 fetch_news.py --mode raw --limit 10
