# ===================================
# NewsLingo News Fetch Configuration
# ===================================

# --- News APIs ---
# Worldnewsapi (get from https://worldnewsapi.com/console)
# Free tier: 50 requests/day
WORLDNEWS_API_KEY=your_worldnews_key_here

# --- Supabase ---
# Get both from https://supabase.com/dashboard/project/qwxsntvobtfjldurswfq/settings/api
SUPABASE_URL=https://qwxsntvobtfjldurswfq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Usage:
#   python3 fetch_news.py 10
#   python3 fetch_news.py --limit 10
